EXPO_PUBLIC_API_BASE_URL=https://chefai-backend-jgth.onrender.com
EXPO_PUBLIC_PLAY_CREDITS_PRODUCT_IDS=chefai_credits_small,chefai_credits_pack,chefai_credits_large
GEMINI_API_KEY=your_backend_gemini_api_key_here
GEMINI_TEXT_MODEL=gemini-3-flash-preview
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Recipe credits billing (server persists wallets under server/data/billing.json)
CHEFAI_INITIAL_CREDITS=15
# CHEFAI_BILLING_DISABLED=1

# --- Google Play credit packs (consumable in-app products) ---
# Android package name (must match app.json expo.android.package)
# CHEFAI_ANDROID_PACKAGE_NAME=com.solaiman.chefai
# Three packs (also the server default if unset). Play Console USD: small $2.99, medium $7.99, large $16.99
CHEFAI_PLAY_PRODUCT_CREDITS_JSON={"chefai_credits_small":30,"chefai_credits_pack":80,"chefai_credits_large":200}
# Legacy single-SKU override (optional): CHEFAI_PLAY_CREDITS_PRODUCT_ID=chefai_credits_pack
# CHEFAI_PLAY_CREDITS_AMOUNT=80
# Service account JSON with Play Developer API (verification strongly recommended):
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=C:\\secrets\\play-service-account.json
# Or paste JSON (newline-sensitive — prefer key file in production):
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON_INLINE={"type":"service_account",...}
#
# Local/dev ONLY — skips Play API verification (never expose publicly):
# CHEFAI_PLAY_VERIFY_DISABLED=1

# Client (Expo): SKUs + optional credits map (defaults match server JSON above)
EXPO_PUBLIC_PLAY_CREDITS_PRODUCT_IDS=chefai_credits_small,chefai_credits_pack,chefai_credits_large
# EXPO_PUBLIC_PLAY_PRODUCT_CREDITS_JSON={"chefai_credits_small":30,"chefai_credits_pack":80,"chefai_credits_large":200}
