{
  "expo": {
    "name": "ChefAI",
    "slug": "chef-ai",
    "scheme": "chefai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.solaiman.chefai",
      "playStoreUrl": "https://play.google.com/store/apps/details?id=com.solaiman.chefai",
      "blockedPermissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "ChefAI needs photo access so you can share your cooking in Community.",
          "microphonePermission": false
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "ChefAI can save dish photos you choose to export to your gallery.",
          "savePhotosPermission": "ChefAI saves dish photos to your gallery when you tap Save photo to gallery.",
          "granularPermissions": []
        }
      ],
      "expo-localization",
      [
        "expo-notifications",
        {
          "color": "#000000",
          "enableBackgroundRemoteNotifications": false
        }
      ],
      "expo-speech-recognition",
      "react-native-iap"
    ],
    "extra": {
      "eas": {
        "projectId": "9c603898-4854-40bc-96bc-a2341cf8dd72"
      }
    }
  }
}
